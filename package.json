{
  "name": "otter-music",
  "private": true,
  "version": "2.4.3",
  "type": "module",
  "workspaces": [
    "shared",
    "functions"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:release": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "ci-test": "node scripts/ci-test.js",
    "preview": "vite preview",
    "resources": "capacitor-assets generate",
    "cap:add:android": "npx cap add android",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:sync:android:release": "npm run build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:update:android": "npx cap update android",
    "version": "node scripts/update-mobile-version.js && git add android/app/build.gradle",
    "build:android:debug": "npm run cap:sync:android && cd android && gradlew.bat assembleDebug",
    "build:android:release": "npm run cap:sync:android && cd android && gradlew.bat assembleRelease",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/file-transfer": "^2.0.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/network": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jofr/capacitor-media-session": "^4.0.0",
    "@otter-music/shared": "*",
    "@tanstack/react-virtual": "^3.13.21",
    "browser-id3-writer": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colord": "^2.9.3",
    "date-fns": "^4.1.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "node-forge": "^1.3.3",
    "pako": "^2.1.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-color-extractor": "^1.1.2",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
